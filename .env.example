# Stagehand can run locally or on Browserbase.
# Use BROWSERBASE when BROWSERBASE_API_KEY is configured.
STAGEHAND_ENV=LOCAL

# Pick the model you want Stagehand to use.
# Refer to the model documentation: https://docs.stagehand.dev/v3/configuration/models#first-class-models
STAGEHAND_MODEL=google/gemini-3-flash-preview

# Required for most hosted LLM providers.
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Required only when STAGEHAND_ENV=BROWSERBASE.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
